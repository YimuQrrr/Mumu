OPENROUTER_API_KEY=your_openrouter_api_key_here
DISCORD_TOKEN=your_discord_bot_token_here

# Optional model/config overrides
OPENROUTER_IMAGE_GENERATION_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_AUDIO_GENERATION_MODEL=google/lyria-3-clip-preview
OPENROUTER_AUDIO_FORMAT=mp3
OPENROUTER_VIDEO_GENERATION_MODEL=google/veo-3.1-fast
OPENROUTER_VIDEO_DURATION=8
OPENROUTER_VIDEO_RESOLUTION=720p
OPENROUTER_VIDEO_ASPECT_RATIO=16:9
